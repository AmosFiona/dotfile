#基础定义

# 选中内容到系统的粘贴板
set selection-clipboard clipboard

# 以宽度自适应打开
set adjust-open "width"

# 垂直居中页面
set vertical-center true

# 始终打开第一页，关闭则记住上次位置
set open-first-page false

# 状态栏显示页码百分比
set statusbar-page-percent true

# 状态栏路径用~代替HOME
#set statusbar-home-title "Zathura"

# 只显示文件名，否则现实完整路径
set window-title-basename true

# 增强搜索，实时搜索
set incremental-search true

# 显示右侧进度条
#set show-v-scrallbar true

# 界面与外观
# 留空可隐藏底部的statusbar   set guioptions ""
set guioptions "cs"

# 字体 支持中文字体
set font "Noto Sans CJK SC Regular 10"

# 页面缓存大小
set page-cache-size 10
# 开启自定义颜色
#set recolor true
# 背景色
#set recolor-darkcolor "#EAEAEA"

# 字体色
#set recolor-lightcolor "\#1F1F1F"

